from tkinter import *
import filework

def open_homepage():

    home = Toplevel()
    home.title("Expense Diary")
    home.geometry("500x500")
    home.configure(bg="#FFAFEB")

    Label(home, text="Expense Homepage",font=("Arial", 18),bg="#FFAFEB").pack(pady=20)

