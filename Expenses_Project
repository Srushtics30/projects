def show_expense(user_id):

    win = Toplevel()
    win.title("Show Expense")
    win.geometry("500x500")
    win.configure(bg="#FFEBAF")

    conn = sqlite3.connect("expense.db")
    cursor = conn.cursor()

    rows = cursor.execute(
        "select * from Exp where UserId=?",
