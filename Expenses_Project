# filework.py
from tkinter import *
import sqlite3

def calculate_expense():

    win = Toplevel()
    win.title("Calculate Expense")
    win.geometry("500x500")
    win.configure(bg="#F6C45C")

    Label(win,text="Enter Your Income",bg="#F6C45C",font=("Arial", 14)).pack(pady=10)

    income_entry = Entry(win)
    income_entry.pack()

    result = Label(win, bg="#F6C45C")
    result.pack(pady=15)

    def calculate():

        conn = sqlite3.connect("expense.db")
        cursor = conn.cursor()

    
        total = cursor.execute("select sum(Amount) from Exp").fetchone()[0]

        conn.close()

        if total is None:
            total = 0

        income = int(income_entry.get())

        balance = income - int(total)

        result.config(text=f"Total Expense: {total}\nRemaining Balance: {balance}",
                      fg="blue")

    Button(win,
           text="Calculate",
           bg="#FFAFEB",
           command=calculate).pack(pady=10)

def show_expense():

    win = Toplevel()
    win.title("Expenses")
    win.geometry("500x400")
    win.configure(bg="#FFAFEB")

    conn = sqlite3.connect("expense.db")
    cursor = conn.cursor()

    rows = cursor.execute("select * from Exp").fetchall()

    conn.close()

    Label(win,
          text="All Expenses",
          font=("Arial", 16),
          bg="#FFAFEB").pack(pady=10)

    for row in rows:
        Label(win,
              text=row,
              bg="#FFAFEB").pack()

