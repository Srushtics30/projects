           bg="#4C9DB0",
           command=win.destroy).pack(pady=10)


def delete_expense(user_id):

    win = Toplevel()
    win.title("Delete Expense")
    win.geometry("500x500")
    win.configure(bg="#FFEBAF")

    Label(win, text="Enter Expense ID",
          bg="#FFEBAF").pack()

    exp_id = Entry(win)
    exp_id.pack()

    def delete():

        conn = sqlite3.connect("expense.db")
        cursor = conn.cursor()

        cursor.execute(
            "delete from Exp where Id=? and UserId=?",
            (exp_id.get(), user_id)
        )

        conn.commit()
        conn.close()

    Button(win, text="Delete",
           bg="#4C9DB0",
           command=delete).pack(pady=10)

    Button(win, text="Back",
           bg="#4C9DB0",
           command=win.destroy).pack(pady=10)


def calculate_expense(user_id):

    win = Toplevel()
    win.title("Calculate Expense")
    win.geometry("500x500")
    win.configure(bg="#FFEBAF")

    Label(win, text="Enter Income",
          bg="#FFEBAF").pack()

    income_entry = Entry(win)
    income_entry.pack()

    result = Label(win, bg="#FFEBAF")
    result.pack(pady=15)

    def calculate():

        conn = sqlite3.connect("expense.db")
        cursor = conn.cursor()

        total = cursor.execute(
            "select sum(Amount) from Exp where UserId=?",
            (user_id,)
        ).fetchone()[0]

        conn.close()

        if total is None:
            total = 0

        income = int(income_entry.get())
        balance = income - total

        result.config(
            text="Total Expense: " + str(total) +
                 "\nRemaining Balance: " + str(balance),
            fg="blue"
        )

    Button(win,
           text="Calculate",
           bg="#4C9DB0",
           command=calculate).pack(pady=10)

    Button(win, text="Back",
           bg="#4C9DB0",
           command=win.destroy).pack(pady=10)


