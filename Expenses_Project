from tkinter import *
import sqlite3
import homepage

root = Tk()
root.title("Login Page")
root.geometry("550x550")
root.configure(bg="#F6C45C")

Label(root, text="Login Page", font=("Arial", 18), bg="#F6C45C").pack(pady=20)

Label(root, text="Username", bg="#F6C45C").pack()
username = Entry(root)
username.pack()

Label(root, text="Password", bg="#F6C45C").pack()
password = Entry(root, show="*")
password.pack()

result = Label(root, bg="#F6C45C")
result.pack(pady=10)

def login():
    conn = sqlite3.connect("expense.db")
    cursor = conn.cursor()

    cursor.execute("select * from user where username=? and password=?",(username.get(), password.get()))

    data = cursor.fetchone()

    if data:
        result.config(text="Login Successful", fg="green")
        homepage.open_homepage()
    else:
        result.config(text="Invalid Login", fg="red")

    conn.close()

Button(root, text="Login", bg="#FFAFEB", command=login).pack(pady=10)

root.mainloop()
