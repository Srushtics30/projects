from tkinter import *
import filework
import sqlite3

def open_homepage(user_id):

    home = Toplevel()
    home.title("Expense Homepage")
    home.geometry("500x500")
    home.configure(bg="#FFEBAF")

    Label(home,
          text="Expense Homepage",
          font=("Arial", 18),
          bg="#FFEBAF").pack(pady=20)

    Button(home,
           text="Insert Expense",
           bg="#4C9DB0",
           command=lambda: filework.insert_expense(user_id)).pack(pady=10)

    Button(home,
           text="Show Expense",
           bg="#4C9DB0",
           command=lambda: filework.show_expense(user_id)).pack(pady=10)

    Button(home,
           text="Delete Expense",
           bg="#4C9DB0",
           command=lambda: filework.delete_expense(user_id)).pack(pady=10)

    Button(home,
           text="Calculate Expense",
           bg="#4C9DB0",
           command=lambda: filework.calculate_expense(user_id)).pack(pady=10)

    conn = sqlite3.connect("expense.db")
    cursor = conn.cursor()

    user = cursor.execute("select username from user where Id=?",
                          (user_id,)).fetchone()
    conn.close()

    if user and user[0] == "admin":

        Label(home,
              text="ADMIN PRIVILEGES",
              fg="red",
              bg="#FFEBAF").pack(pady=15)

        Button(home,
               text="Show All Users",
               bg="#4C9DB0",
               command=filework.show_all_users).pack(pady=5)

        Button(home,
               text="Delete User",
               bg="#4C9DB0",
               command=filework.delete_user).pack(pady=5)

        Button(home,
               text="Show All Expenses",
               bg="#4C9DB0",
               command=filework.show_all_expenses).pack(pady=5)

        Button(home,
               text="Delete Any Expense",
               bg="#4C9DB0",
               command=filework.admin_delete_expense).pack(pady=5)

    Button(home,
           text="Back",
           bg="#4C9DB0",
           command=home.destroy).pack(pady=20)

