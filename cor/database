    conn.commit()
    conn.close()


# ── Row → dict helpers ────────────────────────────────────────────────────────

def _room_row(row):
    keys = ["id","number","floor","type","capacity","status","rent","amenities"]
    return dict(zip(keys, row))

def _student_row(row):
    keys = ["id","name","roll","course","year","room_id","phone","email","guardian","dob","join_date"]
    return dict(zip(keys, row))

def _fee_row(row):
    keys = ["id","student_id","month","amount","status","due_date","paid_date"]
    return dict(zip(keys, row))

def _complaint_row(row):
    keys = ["id","student_id","title","date","status","note"]
    return dict(zip(keys, row))


# ── load() — returns a plain dict, same structure as the JSON version ─────────

def load():
    _setup()
    conn = _connect()
    c = conn.cursor()

    rooms      = [_room_row(r)      for r in c.execute("SELECT * FROM rooms")]
    students   = [_student_row(r)   for r in c.execute("SELECT * FROM students")]
    fees       = [_fee_row(r)       for r in c.execute("SELECT * FROM fees")]
    complaints = [_complaint_row(r) for r in c.execute("SELECT * FROM complaints")]

    conn.close()
    return {"rooms": rooms, "students": students,
            "fees": fees, "complaints": complaints}


# ── save() — writes the whole dict back into SQLite ───────────────────────────

def save(data):
    conn = _connect()
    c = conn.cursor()

    # Delete all rows and re-insert (simple approach)
    c.execute("DELETE FROM rooms")
    for r in data["rooms"]:
        c.execute("INSERT INTO rooms VALUES (?,?,?,?,?,?,?,?)",
                  (r["id"], r["number"], r.get("floor",""), r["type"],
                   r["capacity"], r["status"], r.get("rent",0), r.get("amenities","")))

    c.execute("DELETE FROM students")
    for s in data["students"]:
        c.execute("INSERT INTO students VALUES (?,?,?,?,?,?,?,?,?,?,?)",
                  (s["id"], s["name"], s["roll"], s.get("course",""),
                   s.get("year",""), s.get("room_id",""), s.get("phone",""),
                   s.get("email",""), s.get("guardian",""),
                   s.get("dob",""), s.get("join_date","")))

    c.execute("DELETE FROM fees")
    for f in data["fees"]:
        c.execute("INSERT INTO fees VALUES (?,?,?,?,?,?,?)",
                  (f["id"], f["student_id"], f.get("month",""),
                   f.get("amount",0), f["status"],
                   f.get("due_date",""), f.get("paid_date","")))

    c.execute("DELETE FROM complaints")
    for comp in data["complaints"]:
        c.execute("INSERT INTO complaints VALUES (?,?,?,?,?,?)",
                  (comp["id"], comp["student_id"], comp["title"],
                   comp["date"], comp["status"], comp.get("note","")))

    conn.commit()
    conn.close()


# ── Utility functions (unchanged) ─────────────────────────────────────────────

def new_id():
    import uuid
    return str(uuid.uuid4())[:6].upper()

def today():
    return date.today().isoformat()

def get_room(data, rid):
    return next((r for r in data["rooms"] if r["id"] == rid), None)

def get_student(data, sid):
    return next((s for s in data["students"] if s["id"] == sid), None)

def room_occupants(data, rid):
    return [s for s in data["students"] if s.get("room_id") == rid]
